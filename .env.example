# Docker Compose development services
POSTGRES_DB=recommendation_support
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me-for-local-development
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-for-local-development
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=ap-northeast-1
S3_MARKDOWN_BUCKET=recommendation-support-markdown
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=change-me-for-local-development
DATABASE_URL=postgresql+psycopg://app:change-me-for-local-development@localhost:5432/recommendation_support
REDIS_URL=redis://localhost:6379/0
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-for-local-development
OIDC_ISSUER_URL=http://localhost:8080/realms/recommendation-support
OIDC_AUDIENCE=recommendation-support-api
CORS_ALLOWED_ORIGINS=http://localhost:3000
NUXT_PUBLIC_OIDC_URL=http://localhost:8080
NUXT_PUBLIC_OIDC_REALM=recommendation-support
NUXT_PUBLIC_OIDC_CLIENT_ID=recommendation-support-web
# AI設定のapi_key_secret_refにこの環境変数名を保存する
AI_GATEWAY_API_KEY=replace-with-secret
